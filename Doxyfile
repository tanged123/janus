PROJECT_NAME           = "Janus"
PROJECT_NUMBER         = 2.0.0
PROJECT_BRIEF          = "High-performance C++20 dual-mode numerical framework"
OUTPUT_DIRECTORY       = build/docs
INPUT                  = README.md include docs/design_overview.md docs/janus_usage_guide.md docs/user_guides docs/patterns
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.cpp *.md
USE_MDFILE_AS_MAINPAGE = README.md
GENERATE_HTML          = YES
GENERATE_TREEVIEW      = YES
GENERATE_LATEX         = NO
HAVE_DOT               = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXCLUDE_PATTERNS       = docs/implementation_plans/* docs/saved_work/* docs/design_reviews/* docs/examples/*
WARN_IF_UNDOCUMENTED   = NO
